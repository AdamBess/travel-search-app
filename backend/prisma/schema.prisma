// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Trip {
  id Int @id @default(autoincrement())
  imageUrl String
  name String
  destination String
  hotelTier Int
  rating Float
  ratingAmount Int
  duration Int
  guests Int
  price Float
}